rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Replace Firebase Console "deny all" templates (e.g. `if false`) with this block, then Publish.
    // Any signed-in user (Firebase Auth) may read/write all documents (inventory, sales, quotations).
    // Deploy from repo: npm run deploy:rules  (after firebase login)
    // Or: Console → Firestore → Rules → paste entire file → Publish.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
